# Comma-separated list of trusted IPv4 addresses for OpenClaw dashboard access
TRUSTED_OPENCLAW_CLIENTS=192.168.100.100,192.168.100.101,192.168.100.102
# Raspberry Pi user running OpenClaw
OPENCLAW_USER=u-reg
# Windows PC running Ollama
PC_OLLAMA_IP=192.168.100.103
# Strong token used in openclaw.sample.json
OPENCLAW_TOKEN=replace-me-with-openssl-rand-hex-32
